AGENT_FLEET_HOST=127.0.0.1
AGENT_FLEET_PORT=8787
AGENT_FLEET_STATE=.agent-fleet/control-plane.json
AGENT_FLEET_WORKER_COMMAND=codexyoloproxy

# Project targeting belongs on each goal as workspacePath / Target directory.
# AGENT_FLEET_WORKER_CWD is only a fallback for launch paths without a goal workspace.
# AGENT_FLEET_WORKER_CWD=/Users/yewang/code/project/mahjong

# Preferred when the running server build exposes AGENT_FLEET_WORKER_ARGS:
# AGENT_FLEET_WORKER_COMMAND=codex
# AGENT_FLEET_WORKER_ARGS="exec --json --sandbox workspace-write -"
