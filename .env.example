AGENT_FLEET_HOST=127.0.0.1
AGENT_FLEET_PORT=8787
AGENT_FLEET_STATE=.agent-fleet/control-plane.json

# Optional provider config override. Defaults to XDG_CONFIG_HOME/agent-fleet/config.json
# or $HOME/.config/agent-fleet/config.json.
# AGENT_FLEET_CONFIG=$HOME/.config/agent-fleet/config.json

# Project targeting belongs on each goal as workspacePath / Target directory.
# AGENT_FLEET_WORKER_CWD is only a fallback for launch paths without a goal workspace.
# AGENT_FLEET_WORKER_CWD=$HOME/code/project/mahjong

# Legacy Worker command overrides. When set, these take precedence over provider config.
# Prefer `steward providers set ...` for durable v0.1.0 provider/model setup.
# AGENT_FLEET_WORKER_COMMAND=codex
# AGENT_FLEET_WORKER_ARGS="exec --json --sandbox workspace-write -"
