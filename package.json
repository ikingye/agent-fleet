{
  "name": "agent-fleet",
  "version": "0.1.0",
  "private": true,
  "description": "A Steward Agent control plane for coordinating Worker Agents across projects, worktrees, sessions, and remote execution nodes.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "steward": "dist/cli/main.js"
  },
  "scripts": {
    "dev": "concurrently -k -n server,web \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "docs:dev": "vite --config vite.docs.config.ts --host 127.0.0.1 --port 5174",
    "docs:build": "tsc -p tsconfig.docs.json --noEmit && vite build --config vite.docs.config.ts",
    "docs:preview": "vite preview --config vite.docs.config.ts --host 127.0.0.1 --port 4174",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "check:community": "node scripts/check-community.mjs",
    "check": "npm run typecheck && npm test && npm run check:community"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "fastify": "^5.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.3"
  }
}
